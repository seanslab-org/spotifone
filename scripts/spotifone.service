[Unit]
Description=Spotifone — Bluetooth Mic + Keyboard
After=bluetooth.service
Wants=bluetooth.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 /opt/spotifone/src/main.py --platform mac
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
